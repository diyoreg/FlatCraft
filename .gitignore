# Heavy assets — not tracked in git (3D models, textures, reference renders)
models/
textures/
kitchen sample image hi tech/

# 3D / DCC file formats (in case they appear elsewhere)
*.max
*.fbx
*.FBX
*.obj
*.3ds
*.blend

# 3ds Max backup/autosave
*.bak
autoback/

# Bridge runtime files (created while FC_Bridge.ms is running)
bridge/inbox/
bridge/outbox/
bridge/alive.txt
bridge/launch_request.txt

# Generated by launcher/setup.cmd (contains machine-specific Max path)
launcher/launch.cmd

# User projects are local data; only the sample is tracked
projects/*
!projects/sample/

# Python cache
__pycache__/
*.pyc

# OS junk
Thumbs.db
Desktop.ini
.DS_Store
